# ============================================
# RAG Company Assistant — Environment Variables
# ============================================

# LLM (Ollama)
OLLAMA_URL=http://localhost:11434
LLM_MODEL=llama3
LLM_TEMPERATURE=0.1

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Qdrant (local file mode — no server needed)
QDRANT_PATH=./data/qdrant_storage
QDRANT_COLLECTION=company_docs

# Retrieval
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_FINAL=5

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Auth
SECRET_KEY=change-this-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Server
BACKEND_PORT=8000
FRONTEND_PORT=5173
